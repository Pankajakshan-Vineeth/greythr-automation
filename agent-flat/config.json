      "schedule": "31 18 * * 1-5",
      "scheduleDescription": "Weekdays at 6:30 PM",
      "timezone": "Asia/Kolkata",
      "workflow": "greyhr-logout",
      "params": {
        "loginUrl": "https://basiscloud.greythr.com/uas/portal/auth/login"
      }
