# ============================================================
#  Smart Automation Agent — Environment Variables
#  Copy this file to .env and fill in your real credentials
#  NEVER commit .env to version control
# ============================================================

# GreyHR Credentials
GREYHR_USERNAME=your.username@company.com
GREYHR_PASSWORD=your_greyhr_password

# Optional: Override config.json settings via environment
# AGENT_HEADLESS=true
# AGENT_TIMEZONE=Asia/Kolkata
# AGENT_SLOW_MO=150
# HEALTH_CHECK_PORT=3737

# Optional: Slack/Webhook notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# NOTIFICATION_WEBHOOK=https://your-webhook-url.com/notify
